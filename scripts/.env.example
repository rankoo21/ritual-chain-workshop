# Copy this file to ".env" and fill in your TESTNET key.
#   copy .env.example .env

# A Ritual Chain (chainId 1979) TESTNET private key, funded from the faucet:
#   https://faucet.ritualfoundation.org
# USE A THROWAWAY TESTNET KEY ONLY. Never put a real/mainnet key here.
PRIVATE_KEY=0xyour_testnet_private_key_here

# Optional: override the RPC endpoint (defaults to the public Ritual RPC).
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
